[phases.setup]
nixPkgs = ["ffmpeg"]

[phases.install]
# Сначала ставим зависимости, потом скачиваем браузер в /app/pw-browsers
# (этот путь попадает в финальный Docker-образ, в отличие от /root/.cache)
cmds = [
  "pip install -r requirements.txt",
  "PLAYWRIGHT_BROWSERS_PATH=/app/pw-browsers python -m playwright install chromium"
]
